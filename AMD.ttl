@prefix amd: <http://example.org/amd#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

amd:AMD_Ontology a owl:Ontology ;
    rdfs:label "Age-Related Macular Degeneration Ontology" ;
    rdfs:comment "AMD ontology auto-generated from research abstracts using SCHEMA-MINERpro and Agentic AI" ;
    owl:versionInfo "1.0" .

amd:Acetazolamide a owl:NamedIndividual ;
    rdfs:label "Acetazolamide" .

amd:Age a amd:NonModifiableRiskFactors,
        owl:NamedIndividual ;
    rdfs:label "Age" ;
    amd:causesOrIncreases amd:AMD .

amd:AlzheimersDisease a owl:Class,
        owl:NamedIndividual ;
    rdfs:label "AlzheimersDisease" ;
    rdfs:comment "Neurodegenerative disease affecting the brain and causing memory and thinking problems." ;
    rdfs:subClassOf amd:Disease .

amd:Aspirin a owl:NamedIndividual ;
    rdfs:label "Aspirin" .

amd:BMI a amd:ModifiableRiskFactors,
        owl:NamedIndividual ;
    rdfs:label "BMI" .

amd:Brolucizumab a amd:AntiVEGFTherapy,
        owl:NamedIndividual ;
    rdfs:label "Brolucizumab" .

amd:C2 a amd:RiskGenes,
        owl:NamedIndividual ;
    rdfs:label "C2" .

amd:C3 a amd:RiskGenes,
        owl:NamedIndividual ;
    rdfs:label "C3" .

amd:CNVRegression a amd:SecondaryOutcomes,
        owl:NamedIndividual ;
    rdfs:label "CNVRegression" .

amd:Celecoxib a owl:NamedIndividual ;
    rdfs:label "Celecoxib" ;
    amd:treats amd:ChoroidalNeovascularization,
        amd:WetAMD .

amd:ChoroidalThicknessChange a amd:SecondaryOutcomes,
        owl:NamedIndividual ;
    rdfs:label "ChoroidalThicknessChange" ;
    amd:assessedBy amd:OCT .

amd:CopyNumberVariations a amd:GeneticVariants,
        owl:NamedIndividual ;
    rdfs:label "CopyNumberVariations" .

amd:DarkAdaptationChange a amd:SecondaryOutcomes,
        owl:NamedIndividual ;
    rdfs:label "DarkAdaptationChange" .

amd:DarkAdaptationDeficiency a owl:Class,
        owl:NamedIndividual ;
    rdfs:label "DarkAdaptationDeficiency" ;
    rdfs:comment "Deficiency in dark adaptation, a functional measure in AMD." ;
    rdfs:subClassOf amd:Disease .

amd:Diet a amd:ModifiableRiskFactors,
        owl:NamedIndividual ;
    rdfs:label "Diet" ;
    amd:causesOrIncreases amd:AMD .

amd:ETDRSVisualAcuity a amd:ImagingMethods,
        owl:NamedIndividual ;
    rdfs:label "ETDRSVisualAcuity" .

amd:EnhancedLowVisionRehabilitation a amd:LowVisionRehabilitation,
        owl:NamedIndividual ;
    rdfs:label "EnhancedLowVisionRehabilitation" ;
    amd:treats amd:DepressiveDisorder .

amd:IOLVIP a amd:IntraocularLensImplantation,
        owl:NamedIndividual ;
    rdfs:label "IOLVIP" ;
    amd:treats amd:DryAMD .

amd:ImmunologicalMechanism a owl:Class,
        owl:NamedIndividual ;
    rdfs:label "ImmunologicalMechanism" ;
    rdfs:comment "Immunological mechanisms and their regulatory mechanisms in AMD." ;
    rdfs:subClassOf amd:Disease .

amd:IntermediateAMD a owl:Class,
        owl:NamedIndividual ;
    rdfs:label "IntermediateAMD" ;
    rdfs:comment "Intermediate stage of AMD with moderate drusen and pigment changes." ;
    rdfs:subClassOf amd:Disease .

amd:LOC a amd:RiskGenes,
        owl:NamedIndividual ;
    rdfs:label "LOC" ;
    amd:associatedWith amd:AMD .

amd:LaserInterferometricMeasurementOfFundusPulsation a owl:NamedIndividual ;
    rdfs:label "LaserInterferometricMeasurementOfFundusPulsation" .

amd:LowLevelNightTimeLightTherapy a amd:NightTimeLightTherapy,
        owl:NamedIndividual ;
    rdfs:label "LowLevelNightTimeLightTherapy" ;
    amd:treats amd:EarlyAMD,
        amd:GeographicAtrophy .

amd:MesoZeaxanthin a amd:SupplementTherapy,
        owl:NamedIndividual ;
    rdfs:label "MesoZeaxanthin" ;
    amd:treats amd:AMD .

amd:NonExsudativeAMD a owl:Class,
        owl:NamedIndividual ;
    rdfs:label "NonExsudativeAMD" ;
    amd:isSubtypeOf amd:AMD ;
    rdfs:comment "Non-exsudative form of AMD." ;
    rdfs:subClassOf amd:Disease .

amd:OcularHistoplasmosisSyndrome a owl:Class,
        owl:NamedIndividual ;
    rdfs:label "OcularHistoplasmosisSyndrome" ;
    amd:isSubtypeOf amd:AMD ;
    rdfs:comment "Ocular histoplasmosis syndrome associated with choroidal neovascularization." ;
    rdfs:subClassOf amd:Disease .

amd:Omega-3 a amd:SupplementTherapy,
        owl:NamedIndividual ;
    rdfs:label "Omega-3" .

amd:PazopanibEyeDrops a owl:NamedIndividual ;
    rdfs:label "PazopanibEyeDrops" .

amd:PneumotonometricMeasurementOfPOBF a owl:NamedIndividual ;
    rdfs:label "PneumotonometricMeasurementOfPOBF" .

amd:PreventionOfModerateSevereVisionLoss a amd:PrimaryOutcomes,
        owl:NamedIndividual ;
    rdfs:label "PreventionOfModerateSevereVisionLoss" .

amd:ReadingSpeedImprovement a amd:PrimaryOutcomes,
        owl:NamedIndividual ;
    rdfs:label "ReadingSpeedImprovement" .

amd:RetinalPigmentEpitheliumDetachment a owl:NamedIndividual ;
    rdfs:label "RetinalPigmentEpitheliumDetachment" .

amd:StemCellTherapy a amd:EmergingTherapy,
        owl:NamedIndividual ;
    rdfs:label "StemCellTherapy" .

amd:UltrasoundEvaluation a owl:Class ;
    rdfs:label "UltrasoundEvaluation" ;
    rdfs:comment "Evaluation of ocular tissues using ultrasound techniques." ;
    rdfs:subClassOf amd:Disease .

