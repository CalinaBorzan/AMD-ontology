amd:assessedBy a owl:ObjectProperty ;
    rdfs:label "assessedBy" ;
    rdfs:comment "Indicates that a clinical outcome is assessed by a diagnostic method." ;
    rdfs:domain amd:ClinicalOutcome ;
    rdfs:range amd:DiagnosticMethod .

amd:associatedWith a owl:ObjectProperty ;
    rdfs:label "associatedWith" ;
    rdfs:comment "Indicates that a genetic or molecular biomarker is associated with a disease." ;
    rdfs:domain amd:GeneticMolecularBiomarker ;
    rdfs:range amd:Disease .

amd:causesOrIncreases a owl:ObjectProperty ;
    rdfs:label "causesOrIncreases" ;
    rdfs:comment "Indicates that a risk factor causes or increases the risk of a disease." ;
    rdfs:domain amd:RiskFactor ;
    rdfs:range amd:Disease .

amd:diagnosedBy a owl:ObjectProperty ;
    rdfs:label "diagnosedBy" ;
    rdfs:comment "Indicates that a disease is diagnosed by a diagnostic method." ;
    rdfs:domain amd:Disease ;
    rdfs:range amd:DiagnosticMethod .

amd:hasSymptom a owl:ObjectProperty ;
    rdfs:label "hasSymptom" ;
    rdfs:comment "Indicates that a disease has a symptom." ;
    rdfs:domain amd:Disease ;
    rdfs:range amd:Symptom .

amd:indicates a owl:ObjectProperty ;
    rdfs:label "indicates" ;
    rdfs:comment "Indicates that a biomarker indicates a disease or condition." ;
    rdfs:domain amd:ImagingClinicalBiomarker ;
    rdfs:range amd:Disease .

amd:inhibits a owl:ObjectProperty ;
    rdfs:label "inhibits" ;
    rdfs:comment "Indicates that a treatment inhibits a molecular target." ;
    rdfs:domain amd:Treatment ;
    rdfs:range amd:MolecularTargets .

amd:involvesBiomarker a owl:ObjectProperty ;
    rdfs:label "involvesBiomarker" ;
    rdfs:comment "Links an abstract to a biomarker mentioned in it" .

amd:involvesDiagnosticMethod a owl:ObjectProperty ;
    rdfs:label "involvesDiagnosticMethod" ;
    rdfs:comment "Links an abstract to a diagnostic method mentioned in it" .

amd:involvesGene a owl:ObjectProperty ;
    rdfs:label "involvesGene" ;
    rdfs:comment "Links an abstract to a gene mentioned in it" .

amd:involvesOutcome a owl:ObjectProperty ;
    rdfs:label "involvesOutcome" ;
    rdfs:comment "Links an abstract to a clinical outcome mentioned in it" .

amd:involvesRiskFactor a owl:ObjectProperty ;
    rdfs:label "involvesRiskFactor" ;
    rdfs:comment "Links an abstract to a risk factor mentioned in it" .

amd:involvesTreatment a owl:ObjectProperty ;
    rdfs:label "involvesTreatment" ;
    rdfs:comment "Links an abstract to a treatment mentioned in it" .

amd:isSubtypeOf a owl:ObjectProperty ;
    rdfs:label "isSubtypeOf" ;
    rdfs:comment "Indicates that a disease subtype is a subtype of a parent disease." ;
    rdfs:domain amd:DiseaseSubtype ;
    rdfs:range amd:Disease .

amd:measuredBy a owl:ObjectProperty ;
    rdfs:label "measuredBy" ;
    rdfs:comment "Indicates that a biomarker is measured by a diagnostic method." ;
    rdfs:domain amd:ImagingClinicalBiomarker ;
    rdfs:range amd:DiagnosticMethod .

amd:treats a owl:ObjectProperty ;
    rdfs:label "treats" ;
    rdfs:comment "Indicates that a treatment is used to treat a disease." ;
    rdfs:domain amd:Treatment ;
    rdfs:range amd:Disease .

