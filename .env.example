# Local Ollama (optional — only needed if you use --provider ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Groq API (used by extraction, validation, and literature agents)
GROQ_API_KEY=your-groq-key-here

# UMLS Metathesaurus (used by evaluation/umls/run_umls_validation.py)
UMLS_API_KEY=your-umls-key-here

# NCBI E-utilities (used by literature agent — NCBI requires a contact email
# for polite rate limiting; not validated, just logged on their side)
NCBI_EMAIL=your.email@example.com
