        owl:NamedIndividual ;
    rdfs:label "ClosedCircuitTelevisionTraining" .

amd:CombinationTherapy a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "CombinationTherapy" .

amd:Conbercept a amd:AntiVEGFTherapy,
        owl:NamedIndividual ;
    rdfs:label "Conbercept" ;
    amd:inhibits amd:VEGF ;
