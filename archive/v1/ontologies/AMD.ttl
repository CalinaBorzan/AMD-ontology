@prefix amd: <http://example.org/amd#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

amd:AMDGenotype a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "AMDGenotype" ;
    amd:associatedWith amd:AMD .

amd:AMDPhenotype a amd:Disease,
        owl:NamedIndividual ;
    rdfs:label "AMDPhenotype" .

amd:AMD_Ontology a owl:Ontology ;
    rdfs:label "Age-Related Macular Degeneration Ontology" ;
    rdfs:comment "AMD ontology auto-generated from research abstracts using SCHEMA-MINERpro and Agentic AI" ;
    owl:versionInfo "1.0" .

amd:AMRS2 a amd:Gene,
        owl:NamedIndividual ;
    rdfs:label "AMRS2" ;
    amd:associatedWith amd:AMD .

amd:ARMS2 a amd:Gene,
        owl:NamedIndividual ;
    rdfs:label "ARMS2" ;
    amd:associatedWith amd:AMD,
        amd:AgeRelatedMaculopathy .

amd:AccommodationDisease a amd:Disease,
        owl:NamedIndividual ;
    rdfs:label "AccommodationDisease" ;
    amd:diagnosedBy amd:Ultrasound .

amd:Acetazolamide a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Acetazolamide" ;
    amd:treats amd:Glaucoma .

amd:AdvancedAMD a owl:Class ;
    rdfs:label "AdvancedAMD" ;
    rdfs:comment "Advanced Age-related Macular Degeneration" ;
    rdfs:subClassOf amd:AMD .

amd:Aflibercept a amd:AntiVEGFTherapy,
        owl:NamedIndividual ;
    rdfs:label "Aflibercept" ;
    amd:inhibits amd:VEGF ;
    amd:treats amd:NeovascularAgeRelatedMacularDegeneration,
        amd:WetAMD .

amd:AmyloidBeta a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "AmyloidBeta" .

amd:Antioxidant a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Antioxidant" ;
    amd:treats amd:AMD .

amd:ApoE a amd:Gene,
        owl:NamedIndividual ;
    rdfs:label "ApoE" ;
    amd:associatedWith amd:AMD,
        amd:MacularPigment .

amd:ArterialHypertension a amd:RiskFactor,
        owl:NamedIndividual ;
    rdfs:label "ArterialHypertension" ;
    amd:causesOrIncreases amd:AMD,
        amd:Glaucoma .

amd:ArterialHypotension a amd:RiskFactor,
        owl:NamedIndividual ;
    rdfs:label "ArterialHypotension" ;
