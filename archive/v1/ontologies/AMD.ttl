amd:BF a amd:Gene,
        owl:NamedIndividual ;
    rdfs:label "BF" ;
    amd:associatedWith amd:AMD .

amd:BetaCarotene a amd:AntioxidantSupplement,
        owl:NamedIndividual ;
    rdfs:label "BetaCarotene" .

amd:Bevacizumab a amd:AntiVEGFTherapy,
        owl:NamedIndividual ;
    rdfs:label "Bevacizumab" ;
