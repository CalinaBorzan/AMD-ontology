amd:CX3CR1 a amd:Gene,
        owl:NamedIndividual ;
    rdfs:label "CX3CR1" ;
    amd:associatedWith amd:AMD .

amd:Carotenoid a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "Carotenoid" .

amd:Cataract a amd:Disease,
        owl:NamedIndividual ;
    rdfs:label "Cataract" ;
