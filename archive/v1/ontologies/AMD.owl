  <rdf:Description rdf:about="http://example.org/amd#Aflibercept">
    <rdf:type rdf:resource="http://example.org/amd#AntiVEGFTherapy"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Aflibercept</rdfs:label>
    <amd:treats rdf:resource="http://example.org/amd#NeovascularAgeRelatedMacularDegeneration"/>
    <amd:treats rdf:resource="http://example.org/amd#WetAMD"/>
    <amd:inhibits rdf:resource="http://example.org/amd#VEGF"/>
  </rdf:Description>
