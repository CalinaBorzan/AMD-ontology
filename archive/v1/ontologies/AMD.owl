    <amd:diagnosedBy rdf:resource="http://example.org/amd#PatternElectroretinography"/>
    <amd:associatedWith rdf:resource="http://example.org/amd#GeographicAtrophy"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/amd#StereotacticRadiotherapy">
