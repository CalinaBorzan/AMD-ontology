  <rdf:Description rdf:about="http://example.org/amd#NEI_VFQ-25">
    <rdf:type rdf:resource="http://example.org/amd#DiagnosticMethod"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
