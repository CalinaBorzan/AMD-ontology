  <rdf:Description rdf:about="http://example.org/amd#PhotodynamicTherapy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/amd#Treatment"/>
    <rdfs:label>PhotodynamicTherapy</rdfs:label>
    <rdfs:comment>A type of treatment that uses light to destroy abnormal blood vessels</rdfs:comment>
    <amd:treats rdf:resource="http://example.org/amd#ChoroidalNeovascularization"/>
    <amd:treats rdf:resource="http://example.org/amd#NeovascularAgeRelatedMacularDegeneration"/>
    <amd:treats rdf:resource="http://example.org/amd#NeovascularAMD"/>
    <amd:treats rdf:resource="http://example.org/amd#WetAMD"/>
    <amd:inhibits rdf:resource="http://example.org/amd#ChoroidalNeovascularization"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/amd#ImmunomodulatorySubstance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/amd#Treatment"/>
    <rdfs:label>ImmunomodulatorySubstance</rdfs:label>
    <rdfs:comment>A substance that modulates the immune system</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/amd#BF">
