  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/amd#PreferredRetinalLocus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>PreferredRetinalLocus</rdfs:label>
    <rdfs:comment>The part of the retina that patients naturally start using after central vision is lost</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/amd#AMD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/amd#Disease"/>
    <rdfs:label>AMD</rdfs:label>
    <rdfs:comment>Age-Related Macular Degeneration</rdfs:comment>
    <amd:causesOrIncreases rdf:resource="http://example.org/amd#LowVision"/>
    <amd:diagnosedBy rdf:resource="http://example.org/amd#DiagnosticMethod"/>
    <amd:diagnosedBy rdf:resource="http://example.org/amd#OCT"/>
    <amd:diagnosedBy rdf:resource="http://example.org/amd#ImagingBiomarker"/>
    <amd:diagnosedBy rdf:resource="http://example.org/amd#VisualFunctionBiomarker"/>
    <amd:associatedWith rdf:resource="http://example.org/amd#Biomarker"/>
    <amd:associatedWith rdf:resource="http://example.org/amd#VisualImpairment"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/amd#CerebrovascularEvent">
