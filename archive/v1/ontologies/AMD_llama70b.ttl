@prefix amd: <http://example.org/amd#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

amd:AMD_Ontology a owl:Ontology ;
    rdfs:label "Age-Related Macular Degeneration Ontology" ;
    rdfs:comment "AMD ontology auto-generated from research abstracts using SCHEMA-MINERpro and Agentic AI" ;
    owl:versionInfo "1.0" .

amd:AREDSsupplements a owl:Class ;
    rdfs:label "AREDSsupplements" ;
    rdfs:comment "AREDS/AREDS2 supplements" ;
    rdfs:subClassOf amd:Treatment .

