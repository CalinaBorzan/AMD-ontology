@prefix amd: <http://example.org/amd#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

amd:AMD_Ontology a owl:Ontology ;
    rdfs:label "Age-Related Macular Degeneration Ontology" ;
    rdfs:comment "AMD ontology auto-generated from research abstracts using SCHEMA-MINERpro and Agentic AI" ;
    owl:versionInfo "1.0" .

amd:AMRS2 amd:associatedWith amd:AMD .

amd:ARMS2 a amd:Gene,
        owl:NamedIndividual ;
    rdfs:label "ARMS2" ;
    amd:associatedWith amd:AMD .

amd:Acetazolamide a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Acetazolamide" ;
    amd:treats amd:Glaucoma .

amd:Aflibercept a amd:AntiVEGFTherapy,
        owl:NamedIndividual ;
    rdfs:label "Aflibercept" ;
    amd:inhibits amd:VEGF ;
    amd:treats amd:AMD,
        amd:WetAMD .

amd:Amblyopia a amd:Disease,
        owl:NamedIndividual ;
    rdfs:label "Amblyopia" ;
    amd:diagnosedBy amd:OCT .

amd:ApoE a amd:Gene,
        owl:NamedIndividual ;
    rdfs:label "ApoE" ;
    amd:associatedWith amd:AMD .

amd:Aspirin a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Aspirin" ;
    amd:treats amd:AMD .

amd:Avastin a amd:AntiVEGFTherapy,
        owl:NamedIndividual ;
    rdfs:label "Avastin" ;
    amd:inhibits amd:VEGF ;
    amd:treats amd:WetAMD .

amd:BF a amd:Gene,
        owl:NamedIndividual ;
    rdfs:label "BF" ;
    amd:associatedWith amd:AMD .

amd:Bevacizumab a amd:AntiVEGFTherapy,
        owl:NamedIndividual ;
    rdfs:label "Bevacizumab" ;
    amd:inhibits amd:VEGF ;
    amd:treats amd:WetAMD,
        amd:nAMD .

