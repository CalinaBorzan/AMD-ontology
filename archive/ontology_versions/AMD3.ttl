        owl:NamedIndividual ;
    rdfs:label "CFB" ;
    amd:associatedWith amd:AMD .

amd:CFH a amd:Gene,
        owl:NamedIndividual ;
    rdfs:label "CFH" ;
    amd:associatedWith amd:AMD .

amd:CFI a amd:Gene,
        owl:NamedIndividual ;
    rdfs:label "CFI" ;
    amd:associatedWith amd:AMD .

amd:CNTF a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "CNTF" .

amd:CX3CR1 a amd:Gene,
        owl:NamedIndividual ;
    rdfs:label "CX3CR1" ;
    amd:associatedWith amd:AMD .

amd:Carotenoids a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "Carotenoids" .

amd:Cataract a amd:Disease,
        owl:NamedIndividual ;
    rdfs:label "Cataract" .

amd:Celecoxib a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Celecoxib" ;
    amd:treats amd:AMD .

amd:Conbercept a amd:AntiVEGFTherapy,
        owl:NamedIndividual ;
    rdfs:label "Conbercept" ;
    amd:inhibits amd:VEGF,
        amd:VEGF-A,
        amd:VEGF-B,
        amd:VEGF-C ;
    amd:treats amd:WetAMD .

amd:Copaxone a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Copaxone" ;
    amd:inhibits amd:Microglia ;
    amd:treats amd:DryAMD .

amd:Copper a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Copper" .

amd:Corticosteroid a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Corticosteroid" ;
    amd:inhibits amd:Inflammation ;
    amd:treats amd:AMD .

amd:Dexamethasone a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Dexamethasone" .

amd:Diamox a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Diamox" .

amd:Diet a amd:RiskFactor,
        owl:NamedIndividual ;
    rdfs:label "Diet" .

amd:ERG a amd:DiagnosticMethod,
        owl:NamedIndividual ;
    rdfs:label "ERG" .

amd:ETDRS a amd:DiagnosticMethod,
        owl:NamedIndividual ;
    rdfs:label "ETDRS" .

amd:Eylea a amd:AntiVEGFTherapy,
        owl:NamedIndividual ;
    rdfs:label "Eylea" ;
    amd:inhibits amd:VEGF ;
    amd:treats amd:WetAMD .

amd:Genotype amd:associatedWith amd:AMD .

amd:HTRA1 a amd:Gene,
        owl:NamedIndividual ;
    rdfs:label "HTRA1" ;
    amd:associatedWith amd:AMD .

amd:Hypoxia a amd:RiskFactor,
        owl:NamedIndividual ;
    rdfs:label "Hypoxia" ;
    amd:causesOrIncreases amd:AMD .

amd:ICG a amd:DiagnosticMethod,
        owl:NamedIndividual ;
    rdfs:label "ICG" .

amd:IReST a amd:DiagnosticMethod,
        owl:NamedIndividual ;
    rdfs:label "IReST" .

amd:Infliximab a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Infliximab" .

amd:LOC a amd:Gene,
        owl:NamedIndividual ;
    rdfs:label "LOC" .

amd:LOC387715 a amd:Gene,
        owl:NamedIndividual ;
    rdfs:label "LOC387715" ;
    amd:associatedWith amd:AMD .

amd:Lipofuscin a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "Lipofuscin" ;
    amd:associatedWith amd:AMD,
        amd:GeographicAtrophy ;
    amd:indicates amd:GeographicAtrophy .

amd:Lucentis a amd:AntiVEGFTherapy,
        owl:NamedIndividual ;
    rdfs:label "Lucentis" ;
    amd:inhibits amd:VEGF ;
    amd:treats amd:WetAMD .

amd:Lutein a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "Lutein" ;
    amd:associatedWith amd:AMD ;
    amd:indicates amd:AMD ;
    amd:measuredBy amd:Maculometer ;
    amd:treats amd:AMD .

amd:MAIA a amd:DiagnosticMethod,
        owl:NamedIndividual ;
    rdfs:label "MAIA" .

amd:MOS_SF-36 a amd:DiagnosticMethod,
        owl:NamedIndividual ;
    rdfs:label "MOS SF-36" .

amd:Macuvite a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Macuvite" ;
    amd:inhibits amd:VEGF ;
    amd:treats amd:AMD .

amd:Monocyte a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "Monocyte" .

amd:NEI_VFQ-25 a amd:DiagnosticMethod,
        owl:NamedIndividual ;
    rdfs:label "NEI VFQ-25" .

amd:OT-551 a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "OT-551" ;
    amd:inhibits amd:VEGF ;
    amd:treats amd:GeographicAtrophy .

amd:Occupation a amd:RiskFactor,
        owl:NamedIndividual ;
    rdfs:label "Occupation" ;
    amd:causesOrIncreases amd:ARMD .

amd:PDT a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "PDT" .

amd:PED a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "PED" .

amd:PLEKHA1 a amd:Gene,
        owl:NamedIndividual ;
    rdfs:label "PLEKHA1" ;
    amd:associatedWith amd:AMD .

amd:POT-4 a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "POT-4" .

amd:PRL amd:indicates amd:AMD .

amd:Pazopanib a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Pazopanib" ;
    amd:inhibits amd:VEGF .

amd:Perfluoropropane a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Perfluoropropane" .

amd:Phenylephrine a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Phenylephrine" ;
    amd:treats amd:Glaucoma .

amd:Photocoagulation a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Photocoagulation" ;
    amd:treats amd:AMD .

amd:Pyrosequencing a amd:DiagnosticMethod,
        owl:NamedIndividual ;
    rdfs:label "Pyrosequencing" .

amd:Ranibizumab a amd:AntiVEGFTherapy,
        owl:NamedIndividual ;
    rdfs:label "Ranibizumab" ;
    amd:inhibits amd:VEGF,
        amd:VEGF-A ;
    amd:treats amd:AMD,
        amd:WetAMD .

amd:Refractometer a amd:DiagnosticMethod,
        owl:NamedIndividual ;
    rdfs:label "Refractometer" .

amd:Remicade a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Remicade" .

amd:Retinopathy a amd:Disease,
        owl:NamedIndividual ;
    rdfs:label "Retinopathy" .

amd:Rheohemapheresis a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Rheohemapheresis" .

amd:Rheopheresis a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Rheopheresis" ;
    amd:treats amd:DryAMD .

amd:SRT a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "SRT" ;
    amd:treats amd:WetAMD .

amd:Saffron a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Saffron" ;
    amd:treats amd:DryAMD .

amd:Sirolimus a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Sirolimus" ;
    amd:inhibits amd:Inflammation ;
    amd:treats amd:GeographicAtrophy .

amd:Smoking a amd:RiskFactor,
        owl:NamedIndividual ;
    rdfs:label "Smoking" ;
    amd:causesOrIncreases amd:AMD,
        amd:ARMD .

amd:Sonepcizumab a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Sonepcizumab" ;
    amd:inhibits amd:S1P .

amd:Sunlight a amd:RiskFactor,
        owl:NamedIndividual ;
    rdfs:label "Sunlight" ;
    amd:causesOrIncreases amd:ARMD .

amd:TAS2R38 a amd:Gene,
        owl:NamedIndividual ;
    rdfs:label "TAS2R38" .

amd:Tropicamide a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Tropicamide" .

amd:Uveitis a amd:Disease,
        owl:NamedIndividual ;
    rdfs:label "Uveitis" ;
    amd:diagnosedBy amd:OCT .

amd:VEGFR a amd:Gene,
        owl:NamedIndividual ;
    rdfs:label "VEGFR" ;
    amd:associatedWith amd:AMD .

amd:VEGFR1 a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "VEGFR1" .

amd:VEGFR2 a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "VEGFR2" .

amd:Verteporfin a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Verteporfin" ;
    amd:treats amd:WetAMD .

amd:Visudyne a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Visudyne" .

amd:Vitrectomy a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Vitrectomy" ;
    amd:treats amd:AMD .

amd:Zeaxanthin a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "Zeaxanthin" ;
    amd:associatedWith amd:AMD ;
    amd:indicates amd:AMD ;
    amd:measuredBy amd:Maculometer ;
    amd:treats amd:AMD .

amd:Zinc a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "Zinc" .

amd:assessedBy a owl:ObjectProperty ;
    rdfs:label "assessedBy" ;
    rdfs:comment "A clinical outcome assessed by a method" ;
    rdfs:domain amd:ClinicalOutcome ;
    rdfs:range amd:DiagnosticMethod .

amd:associatedWith a owl:ObjectProperty ;
    rdfs:label "associatedWith" ;
    rdfs:comment "A gene associated with a disease" ;
    rdfs:domain amd:GeneticBiomarker ;
    rdfs:range amd:Disease .

amd:causesOrIncreases a owl:ObjectProperty ;
    rdfs:label "causesOrIncreases" ;
    rdfs:comment "A risk factor that causes or increases a disease" ;
    rdfs:domain amd:RiskFactor ;
    rdfs:range amd:Disease .

amd:diagnosedBy a owl:ObjectProperty ;
    rdfs:label "diagnosedBy" ;
    rdfs:comment "A disease diagnosed via a method" ;
    rdfs:domain amd:Disease ;
    rdfs:range amd:DiagnosticMethod .

amd:hasSymptom a owl:ObjectProperty ;
    rdfs:label "hasSymptom" ;
    rdfs:comment "A disease has a clinical symptom" ;
    rdfs:domain amd:Disease ;
    rdfs:range amd:ClinicalOutcome .

amd:iSONEP a amd:Treatment,
        owl:NamedIndividual ;
    rdfs:label "iSONEP" .

amd:indicates a owl:ObjectProperty ;
    rdfs:label "indicates" ;
    rdfs:comment "A biomarker that indicates a disease" ;
    rdfs:domain amd:Biomarker ;
    rdfs:range amd:Disease .

amd:inhibits a owl:ObjectProperty ;
    rdfs:label "inhibits" ;
    rdfs:comment "A treatment that inhibits a molecular target" ;
    rdfs:domain amd:Treatment ;
    rdfs:range amd:MolecularTarget .

amd:measuredBy a owl:ObjectProperty ;
    rdfs:label "measuredBy" ;
    rdfs:comment "A biomarker measured by a method" ;
    rdfs:domain amd:Biomarker ;
    rdfs:range amd:DiagnosticMethod .

amd:rs1061170 a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "rs1061170" ;
    amd:associatedWith amd:AMD .

amd:rs11200638 a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "rs11200638" ;
    amd:associatedWith amd:AMD .

amd:treats a owl:ObjectProperty ;
    rdfs:label "treats" ;
    rdfs:comment "A treatment that manages a disease" ;
    rdfs:domain amd:Treatment ;
    rdfs:range amd:Disease .

amd:Angiography a amd:DiagnosticMethod,
        owl:NamedIndividual ;
    rdfs:label "Angiography" .

amd:CNIB a amd:DiagnosticMethod,
        owl:NamedIndividual ;
    rdfs:label "CNIB" .

amd:Electroretinography a amd:DiagnosticMethod,
        owl:NamedIndividual ;
    rdfs:label "Electroretinography" .

amd:Microglia a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "Microglia" ;
    amd:associatedWith amd:AMD ;
    amd:indicates amd:AMD .

amd:Morphometry a amd:DiagnosticMethod,
        owl:NamedIndividual ;
    rdfs:label "Morphometry" .

amd:PAECT a amd:DiagnosticMethod,
        owl:NamedIndividual ;
    rdfs:label "PAECT" .

amd:S1P a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "S1P" ;
    amd:associatedWith amd:AMD .

amd:Ultrasound a amd:DiagnosticMethod,
        owl:NamedIndividual ;
    rdfs:label "Ultrasound" .

amd:VEGF-B a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "VEGF-B" ;
    amd:associatedWith amd:AMD .

amd:VEGF-C a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "VEGF-C" .

amd:nAMD amd:diagnosedBy amd:OCT .

amd:Drusen a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "Drusen" ;
    amd:associatedWith amd:AMD,
        amd:DryAMD ;
    amd:indicates amd:AMD,
        amd:DryAMD .

amd:Endophthalmitis a amd:ClinicalOutcome,
        owl:NamedIndividual ;
    rdfs:label "Endophthalmitis" .

amd:Glaucoma a amd:Disease,
        owl:NamedIndividual ;
    rdfs:label "Glaucoma" ;
    amd:diagnosedBy amd:Morphometry,
        amd:OCT,
        amd:Ultrasound .

amd:Inflammation a amd:RiskFactor,
        owl:NamedIndividual ;
    rdfs:label "Inflammation" ;
    amd:causesOrIncreases amd:AMD,
        amd:GeographicAtrophy .

amd:Maculometer a amd:DiagnosticMethod,
        owl:NamedIndividual ;
    rdfs:label "Maculometer" .

amd:VEGF-A a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "VEGF-A" ;
    amd:associatedWith amd:AMD,
        amd:WetAMD .

amd:ARMD a amd:Disease,
        owl:NamedIndividual ;
    rdfs:label "ARMD" .

amd:ClinicalOutcome a owl:Class ;
    rdfs:label "ClinicalOutcome" ;
    rdfs:comment "A measurable result of a treatment or disease progression" .

amd:DryAMD a owl:Class ;
    rdfs:label "DryAMD" ;
    amd:hasSymptom amd:Drusen,
        amd:GeographicAtrophy ;
    rdfs:comment "Dry Age-Related Macular Degeneration" ;
    rdfs:subClassOf amd:AMD .

amd:AntiVEGFTherapy a owl:Class ;
    rdfs:label "AntiVEGFTherapy" ;
    amd:inhibits amd:VEGF ;
    amd:treats amd:WetAMD ;
    rdfs:comment "Therapy that inhibits VEGF" ;
    rdfs:subClassOf amd:Treatment .

amd:GeographicAtrophy a owl:Class ;
    rdfs:label "GeographicAtrophy" ;
    amd:diagnosedBy amd:OCT ;
    rdfs:comment "Retinal cell death areas" ;
    rdfs:subClassOf amd:DryAMD .

amd:OCT a amd:DiagnosticMethod,
        owl:NamedIndividual ;
    rdfs:label "OCT" .

amd:RiskFactor a owl:Class ;
    rdfs:label "RiskFactor" ;
    rdfs:comment "A factor that increases the likelihood of developing a disease" .

amd:VEGF a amd:Biomarker,
        owl:NamedIndividual ;
    rdfs:label "VEGF" ;
    amd:associatedWith amd:WetAMD .

amd:WetAMD a owl:Class ;
    rdfs:label "WetAMD" ;
    amd:diagnosedBy amd:Angiography,
        amd:Electroretinography,
        amd:OCT ;
    amd:hasSymptom amd:Endophthalmitis ;
    rdfs:comment "Neovascular Age-Related Macular Degeneration" ;
    rdfs:subClassOf amd:AMD .

amd:Disease a owl:Class ;
    rdfs:label "Disease" ;
    rdfs:comment "A medical condition affecting the human body" .

amd:Gene a owl:Class ;
    rdfs:label "Gene" ;
    rdfs:comment "Any gene related to a disease" ;
    rdfs:subClassOf amd:Biomarker .

amd:DiagnosticMethod a owl:Class ;
    rdfs:label "DiagnosticMethod" ;
    rdfs:comment "A procedure or test used to diagnose a disease" .

amd:Biomarker a owl:Class ;
    rdfs:label "Biomarker" ;
    rdfs:comment "A measurable indicator of a biological state or condition" .

amd:Treatment a owl:Class ;
    rdfs:label "Treatment" ;
    rdfs:comment "A medical intervention used to manage or cure a disease" .

amd:AMD a owl:Class ;
    rdfs:label "AMD" ;
    amd:diagnosedBy amd:CNIB,
        amd:OCT,
        amd:PAECT ;
    amd:hasSymptom amd:Drusen,
        amd:Endophthalmitis,
        amd:GeographicAtrophy ;
    rdfs:comment "Age-Related Macular Degeneration" ;
    rdfs:subClassOf amd:Disease .

